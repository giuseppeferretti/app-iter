# Configuração do App Iter — copie para .env e preencha com valores reais.
#
# Detalhes de cada variável estão em infra/SETUP_ASAAS.md.

# ── Supabase (auth + tabela subscribers) ─────────────────────────────────────
# Obtido em supabase.com > seu projeto > Settings > API
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PLACEHOLDER

# ── Asaas (link de pagamento da assinatura) ──────────────────────────────────
# URL pública gerada no painel Asaas > Cobranças > Links de Pagamento.
# Sandbox: https://sandbox.asaas.com/c/XXX
# Produção: https://www.asaas.com/c/XXX
ASAAS_CHECKOUT_URL=https://sandbox.asaas.com/c/SEU-LINK-AQUI

# ── DEV mode ─────────────────────────────────────────────────────────────────
# 1 = pula onboarding/licença, mostra pílula DEV no canto (desenvolvimento).
# 0 = fluxo real de licença (use em produção e quando testar end-to-end).
APP_ANAC_DEV=1
